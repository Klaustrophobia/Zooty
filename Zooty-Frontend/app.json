{
  "expo": {
    "name": "Zooty-Frontend",
    "slug": "Zooty-Frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zootyfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Zooty necesita tu ubicación para mostrarte profesionales cercanos a tu área.",
        "NSLocationAlwaysUsageDescription": "Zooty necesita tu ubicación para mostrarte profesionales cercanos.",
        "UIBackgroundModes": ["location"],
        "NSPhotoLibraryUsageDescription": "Zooty necesita acceder a tu galería para seleccionar una foto de perfil.",
        "NSCameraUsageDescription": "Zooty necesita acceder a tu cámara para tomar una foto de perfil."
      },
      "config": {
        "googleMapsApiKey": "TU_API_KEY_DE_IOS_AQUI"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "TU_API_KEY_DE_ANDROID_AQUI"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permite a Zooty acceder a tu ubicación para mostrarte profesionales cercanos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Zooty necesita acceder a tu galería para seleccionar una foto de perfil.",
          "cameraPermission": "Zooty necesita acceder a tu cámara para tomar una foto de perfil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}